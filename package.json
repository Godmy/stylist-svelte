{
	"name": "stylist-svelte",
	"version": "1.0.1",
	"description": "A comprehensive Svelte 5 UI component library with Tailwind CSS",
	"type": "module",
	"author": "Godmy & AI-Team",
	"license": "MIT",
	"packageManager": "yarn@4.5.1",
	"keywords": [
		"svelte",
		"svelte5",
		"ui",
		"components",
		"tailwind",
		"design-system"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Godmy/stylist-svelte.git"
	},
	"bugs": {
		"url": "https://github.com/Godmy/stylist-svelte/issues"
	},
	"homepage": "https://github.com/Godmy/stylist-svelte#readme",
	"scripts": {
		"dev": "vite dev",
		"dev:with-json": "yarn json:generate && vite dev",
		"build": "yarn analyze && svelte-package && publint",
		"preview": "vite preview",
		"package": "svelte-package",
		"tsc": "tsc --noEmit",
		"prepublishOnly": "npm run build",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
		"validate": "yarn lint && yarn tsc && yarn check",
		"test": "vitest",
		"test:unit": "vitest run",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"clean": "rm -rf dist .svelte-kit node_modules/.vite",
		"audit": "yarn audit",
		"depcheck": "depcheck",
		"madge:graph": "madge --image ./madge-graph.svg ./src/index.ts",
		"madge:circular": "madge --circular ./src/index.ts",
		"json:generate": "tsx scripts/orchestrator.ts",
		"json:predev": "yarn json:generate",
		"analyze": "tsx scripts/orchestrator.ts",
		"analyze:build": "tsx scripts/orchestrator.ts",
		"analyze:tokens": "tsx scripts/analyzers/analyze-tokens.ts",
		"analyze:contracts": "tsx scripts/analyzers/analyze-contracts.ts",
		"analyze:models": "tsx scripts/analyzers/analyze-models.ts",
		"analyze:styles": "tsx scripts/analyzers/analyze-styles.ts",
		"analyze:components": "tsx scripts/analyzers/analyze-components.ts",
		"analyze:icons": "tsx scripts/analyzers/analyze-icons.ts",
		"dep-tree": "tsx scripts/dependency-tree.ts",
		"dep-short": "tsx scripts/dependency-short.ts",
		"token-audit": "tsx scripts/token-audit.ts",
		"contracts-analysis": "tsx scripts/contracts-analysis.ts",
		"samo:molecular-organization": "tsx scripts/samo/molecular-organization/generate.ts",
		"samo:solid": "tsx scripts/samo/solid/generate.ts",
		"samo:atomic-design": "tsx scripts/samo/atomic-design/generate.ts",
		"samo:component-reuse": "tsx scripts/samo/component-reuse/generate.ts",
		"samo:inventory": "tsx scripts/samo/inventory/generate.ts",
		"samo:all": "yarn samo:atomic-design && yarn samo:solid && yarn samo:molecular-organization && yarn samo:component-reuse && yarn samo:inventory"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"peerDependenciesMeta": {
		"zod": {
			"optional": true
		}
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.43.2",
		"@sveltejs/package": "^2.3.10",
		"@sveltejs/vite-plugin-svelte": "^6.2.0",
		"@tailwindcss/vite": "^4.1.18",
		"@testing-library/svelte": "^5.2.8",
		"@types/node": "^22.0.0",
		"@vitest/coverage-v8": "^3.2.4",
		"autoprefixer": "^10.4.21",
		"baseline-browser-mapping": "^2.9.19",
		"depcheck": "^1.4.7",
		"eslint": "^9.36.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.12.4",
		"madge": "^8.0.0",
		"postcss": "^8.4.49",
		"prettier": "^3.6.2",
		"prettier-plugin-svelte": "^3.4.0",
		"publint": "^0.3.15",
		"svelte": "^5.39.5",
		"svelte-check": "^4.3.2",
		"svelte-preprocess": "^6.0.3",
		"tailwindcss": "^4.1.17",
		"tsx": "^4.21.0",
		"typescript": "^5.9.2",
		"typescript-eslint": "^8.44.1",
		"vite": "^7.1.7",
		"vitest": "^3.2.4"
	},
	"dependencies": {
		"marked": "^17.0.0",
		"shiki": "^3.15.0"
	},
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts"
}

